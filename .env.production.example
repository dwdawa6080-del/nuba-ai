# Copy this to .env.production and fill in your values before deploying

# Backend
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
MONGODB_URI=mongodb://mongo:27017/nuba-ai
ALLOWED_ORIGINS=https://yourdomain.com

# Vision — Ollama must be reachable from the backend container
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2-vision

# Translation (optional — increases free quota from 5K to 50K chars/day)
MYMEMORY_EMAIL=your@email.com

# Frontend build arg
REACT_APP_API_URL=https://api.yourdomain.com
